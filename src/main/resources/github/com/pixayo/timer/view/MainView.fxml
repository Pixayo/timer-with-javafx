<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<StackPane fx:id="root"
           prefHeight="250.0"
           prefWidth="300.0"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="github.com.pixayo.timer.controller.MainViewController">

    <VBox alignment="CENTER" spacing="15.0">

        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
        </padding>

        <Label fx:id="timerLabel"
               text="00:00"
               style="-fx-font-family: 'Monospaced'; -fx-font-weight: bold; -fx-font-size: 48;"
        />

        <Label fx:id="previousTimerLabel"
               style="-fx-font-family: 'Monospaced'; -fx-text-fill: #A1A1A1; -fx-font-size: 12;"
        />

        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="startButton"
                    text="Start"
                    onAction="#handleStart"
            />

            <Button fx:id="stopResetButton"
                    text="Reset"
                    onAction="#handleStopReset"
            />

        </HBox>
    </VBox>

    <Button fx:id="settingsButton"
            onAction="#goToSettings"
            StackPane.alignment="TOP_LEFT"
            styleClass="icon-button"> <graphic>
        <ImageView fx:id="settingsIcon"
                   fitHeight="24.0"
                   fitWidth="24.0"
                   pickOnBounds="true"
                   preserveRatio="true" />
        </graphic>

            <StackPane.margin>
                <Insets left="15.0" top="15.0" />
            </StackPane.margin>
    </Button>

</StackPane>